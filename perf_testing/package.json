{
  "name": "perf_testing",
  "version": "1.1.0",
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "npm run setup",
    "setup": "npm run setup:win --if-present || npm run setup:unix",
    "setup:win": "node -e \"if(process.platform!=='win32')process.exit(1)\" && python setup_env.py",
    "setup:unix": "python3 setup_env.py",
    "build": "npm run build:python",
    "postbuild": "npm run cp:readme && npm run cp:hapray && npm run cp:_internal",
    "build:python": "./.venv/bin/pyinstaller -y main.spec || .\\\\.venv\\\\Scripts\\\\pyinstaller.exe -y main.spec",
    "lint": "./.venv/bin/tox -e lint || .\\\\.venv\\\\Scripts\\\\tox.exe -e lint",
    "lint:fix": "./.venv/bin/tox -e lint-fix || .\\\\.venv\\\\Scripts\\\\tox.exe -e lint-fix",
    "test": "./.venv/bin/tox || .\\\\.venv\\\\Scripts\\\\tox.exe",
    "prepack": "npm run build:python && node ../build/zip.js ArkAnalyzer-HapRay",
    "cp:readme": "node ../build/copy.js perf_testing/dist/README.md dist/README.md",
    "cp:hapray": "node ../build/copy.js perf_testing/dist/ArkAnalyzer-HapRay/ArkAnalyzer-HapRay dist/ArkAnalyzer-HapRay",
    "cp:_internal": "node ../build/copy.js perf_testing/dist/ArkAnalyzer-HapRay/_internal dist/_internal"
  },
  "author": "",
  "license": "ISC",
  "description": ""
}
