{
  "name": "hapray",
  "version": "1.4.9",
  "description": "Code-oriented Performance Analysis for OpenHarmony Apps",
  "private": true,
  "files": [],
  "workspaces": [
    "web",
    "tools/static_analyzer",
    "perf_testing",
    "tools/optimization_detector",
    "tools/symbol_recovery",
    "desktop"
  ],
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "npm run prebuild && npm run build --ws",
    "release": "node scripts/release.js",
    "lint": "npm run lint --ws",
    "lint:fix": "npm run lint:fix --ws",
    "test": "node scripts/e2e_test.js ./dist",
    "test-release": "node scripts/test_release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitcode.com/SMAT/ArkAnalyzer-HapRay.git"
  },
  "bugs": {
    "url": "https://gitcode.com/SMAT/ArkAnalyzer-HapRay/issues"
  },
  "homepage": "https://gitcode.com/SMAT/ArkAnalyzer-HapRay#readme",
  "devDependencies": {
    "xlsx": "^0.18.5"
  }
}
