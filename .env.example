# OpenAI API Configuration
# 复制此文件为 .env 并填入你的配置

# 必需: OpenAI API密钥
OPENAI_API_KEY=your-api-key-here

# 可选: 使用的模型 (默认: gpt-4o)
# 可选值: gpt-4o, gpt-4o-mini, gpt-4-vision-preview
OPENAI_MODEL=gpt-4o

# 可选: API基础URL (默认: https://api.openai.com/v1)
# Azure OpenAI 示例: https://your-resource.openai.azure.com
# 本地模型示例: http://localhost:8000/v1
OPENAI_BASE_URL=https://api.openai.com/v1
