{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArkAnalyzer-HapRay",
  "version": "1.5.1",
  "identifier": "arkanalyzer.hapray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "ArkAnalyzer-HapRay",
        "url": "/",
        "decorations": true,
        "dragDropEnabled": false,
        "zoomHotkeysEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "tools"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/arkanalyzer-hapray/tools": "./tools/**"
        }
      }
    }
  }
}