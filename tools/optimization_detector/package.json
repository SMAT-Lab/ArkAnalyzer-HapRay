{
  "name": "optimization-detector",
  "version": "1.5.3",
  "description": "二进制文件优化级别和LTO检测工具",
  "files": [
    "dist",
    "optimization_detector"
  ],
  "scripts": {
    "postinstall": "npm run setup",
    "setup": "node ../../scripts/python_setup.js --extra dev",
    "build": "npm run build:onefile",
    "build:onefile": "uv run --extra dev pyinstaller -y --distpath ../../dist/tools/opt-detector optimization_detector.spec",
    "postbuild": "webpack --config webpack.config.js",
    "clean": "rm -rf build/ dist/ .venv *.egg-info optimization_detector.egg-info dist/*.zip ../../dist/tools/opt-detector",
    "install:dev": "npm run setup",
    "lint": "uv run --extra dev tox -e ruff",
    "lint:fix": "uv run --extra dev tox -e ruff-fix"
  },
  "author": "Huawei Device Co., Ltd.",
  "license": "Apache-2.0",
  "keywords": [
    "binary",
    "optimization",
    "detector",
    "lto",
    "compiler",
    "flags"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitcode.com/SMAT/ArkAnalyzer-HapRay"
  },
  "devDependencies": {
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "copy-webpack-plugin": "^14.0.0",
    "archiver": "^7.0.1"
  }
}

