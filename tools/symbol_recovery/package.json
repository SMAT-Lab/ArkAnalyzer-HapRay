{
  "name": "symbol-recovery",
  "version": "1.0.0",
  "description": "二进制符号恢复工具：支持 perf.data 和 Excel 偏移量两种模式",
  "files": [
    "dist",
    "symbol_recovery"
  ],
  "scripts": {
    "postinstall": "npm run setup",
    "setup": "npm run setup:win --if-present || npm run setup:unix",
    "setup:win": "node -e \"if(process.platform!=='win32')process.exit(1)\" && python setup_env.py",
    "setup:unix": "python3 setup_env.py",
    "build": "npm run build:onedir",
    "build:onedir": "./.venv/bin/pyinstaller -y symbol_recovery.spec || .\\\\.venv\\\\Scripts\\\\pyinstaller.exe -y symbol_recovery.spec",
    "postbuild": "node ../../scripts/pack.js symbol-recovery dist/symbol-recovery ../../dist/tools/trace_streamer_binary README.md",
    "clean": "rm -rf build/ dist/ *.egg-info symbol_recovery.egg-info dist/*.zip",
    "install:dev": "npm run setup",
    "lint": "./.venv/bin/tox -e ruff || .\\\\.venv\\\\Scripts\\\\tox.exe -e ruff || python3 -m ruff check .",
    "lint:fix": "./.venv/bin/tox -e ruff-fix || .\\\\.venv\\\\Scripts\\\\tox.exe -e ruff-fix || python3 -m ruff check --fix ."
  },
  "author": "Huawei Device Co., Ltd.",
  "license": "Apache-2.0",
  "keywords": [
    "binary",
    "symbol",
    "recovery",
    "perf",
    "disassembly",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitcode.com/SMAT/ArkAnalyzer-HapRay"
  }
}

