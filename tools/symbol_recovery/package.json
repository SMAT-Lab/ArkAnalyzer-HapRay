{
  "name": "symbol-recovery",
  "version": "1.5.2",
  "description": "二进制符号恢复工具：支持 perf.data 和 Excel 偏移量两种模式",
  "files": [
    "dist",
    "symbol_recovery"
  ],
  "scripts": {
    "postinstall": "npm run setup",
    "setup": "node ../../scripts/python_setup.js --extra dev",
    "build": "npm run build:onefile",
    "build:onefile": "uv run --extra dev pyinstaller -y --distpath ../../dist/tools/symbol-recovery symbol_recovery.spec",
    "build:onedir": "npm run build:onefile",
    "postbuild": "webpack --config webpack.config.js",
    "clean": "rm -rf build/ dist/ .venv *.egg-info symbol_recovery.egg-info dist/*.zip ../../dist/tools/symbol-recovery",
    "install:dev": "npm run setup",
    "lint": "uv run --extra dev tox -e ruff",
    "lint:fix": "uv run --extra dev tox -e ruff-fix"
  },
  "keywords": [
    "binary",
    "symbol",
    "recovery",
    "perf",
    "disassembly",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitcode.com/SMAT/ArkAnalyzer-HapRay"
  },
  "devDependencies": {
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "copy-webpack-plugin": "^14.0.0",
    "archiver": "^7.0.1",
    "adm-zip": "^0.5.16"
  }
}

